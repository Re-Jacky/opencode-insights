{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@rejacky/opencode-insights",
  "version": "0.1.1",
  "description": "OpenCode plugin for local request capture, TPS metrics, and subagent status visibility.",
  "type": "module",
  "author": "opencode-insights contributors",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "opencode-insights": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "DEVELOPMENT.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run test && npm run build",
    "prepack": "npm run build",
    "prepublishOnly": "npm run verify"
  },
  "keywords": [
    "opencode",
    "plugin",
    "llm",
    "sqlite",
    "tps",
    "subagent"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.13"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.15.0 <2",
    "@opentui/core": ">=0.4.0 <0.5",
    "@opentui/solid": ">=0.4.0 <0.5",
    "solid-js": "1.9.12"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.13",
    "@opentui/core": "^0.4.3",
    "@opentui/solid": "^0.4.3",
    "@types/node": "^24.12.2",
    "solid-js": "1.9.12",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
